---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404: Not Found">
  <div class="relative isolate min-h-[calc(100vh-64px)] flex items-center justify-center overflow-hidden bg-canvas">
    {/* Background Mesh Gradient */}
    <div class="absolute inset-0 -z-10 overflow-hidden" aria-hidden="true">
      <div class="mesh-gradient absolute left-[50%] top-[50%] h-[800px] w-[1600px] -translate-x-[50%] -translate-y-[50%] opacity-20 blur-3xl" />
    </div>

    <div class="max-w-2xl mx-auto px-s-md py-s-section text-center">
      <div class="inline-flex items-center gap-s-xs px-s-sm py-1 rounded-full border border-hairline bg-canvas-soft-2 mb-s-xl animate-in fade-in slide-in-from-top-4 duration-700">
        <span class="h-1.5 w-1.5 rounded-full bg-error animate-pulse"></span>
        <p class="caption-mono text-[10px] uppercase tracking-widest text-error font-semibold">Error 404</p>
      </div>

      <h1 class="display-xl text-[48px] sm:text-[72px] md:text-[96px] tracking-[-0.05em] mb-s-lg animate-in fade-in slide-in-from-bottom-8 duration-700">
        Lost in the <span class="text-mute italic">stack.</span>
      </h1>

      <p class="body-md md:body-lg text-body mb-s-2xl max-w-md mx-auto animate-in fade-in slide-in-from-bottom-8 duration-700 delay-200">
        The page you are looking for does not exist or has been moved. 
        Perhaps it was bunked?
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-s-md animate-in fade-in slide-in-from-bottom-12 duration-700 delay-300">
        <a href="/" class="button-primary h-12 px-s-xl flex items-center gap-s-sm shadow-level-4 transition-transform hover:scale-[1.02] active:scale-[0.98]">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Return Home
        </a>
        <button onclick="window.history.back()" class="button-secondary h-12 px-s-xl flex items-center gap-s-sm shadow-level-1 transition-transform hover:scale-[1.02] active:scale-[0.98]">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 14 4 9l5-5"/><path d="M4 9h12a5 5 0 0 1 5 5v5"/></svg>
          Go Back
        </button>
      </div>

      <div class="mt-s-4xl pt-s-xl border-t border-hairline/50 flex flex-col items-center gap-s-md opacity-50">
        <p class="caption-mono text-[10px] uppercase tracking-widest text-mute">Diagnostics</p>
        <div class="grid grid-cols-2 gap-x-s-xl gap-y-s-sm text-left">
          <div class="space-y-1">
            <p class="caption-mono text-[9px] text-mute uppercase font-bold">Trace ID</p>
            <p class="caption-mono text-[10px] text-ink font-medium">ATT-{Math.random().toString(36).substring(2, 9).toUpperCase()}</p>
          </div>
          <div class="space-y-1">
            <p class="caption-mono text-[9px] text-mute uppercase font-bold">Status</p>
            <p class="caption-mono text-[10px] text-ink font-medium underline decoration-error/30">PAGE_NOT_FOUND</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
