---
import Layout from '../layouts/Layout.astro';
---

<Layout 
	title="Contact Us - Attendance Tracker"
	description="Have questions or feedback? Get in touch with the Attendance Tracker team."
>
	<div class="max-w-3xl mx-auto px-s-md py-s-4xl md:py-s-section">
		<h1 class="display-lg mb-s-xl tracking-tighter">Contact Us</h1>
		
		<div class="space-y-s-xl body-md text-body leading-relaxed">
			<p>
				We'd love to hear from you. Whether you have a feature request, found a bug, or just want to say hi, feel free to reach out.
			</p>
			
			<div className="grid grid-cols-1 md:grid-cols-2 gap-s-xl mt-s-2xl">
				<div className="card-marketing p-s-xl border border-hairline/50">
					<h3 className="body-md font-semibold text-ink mb-s-xs">Support</h3>
					<p className="body-sm text-body">Email us at support@attendancetracker.xyz for any technical issues.</p>
				</div>
				<div className="card-marketing p-s-xl border border-hairline/50">
					<h3 className="body-md font-semibold text-ink mb-s-xs">Twitter</h3>
					<p className="body-sm text-body">Follow us @AttendanceTrack for updates and tips.</p>
				</div>
			</div>

			<div className="mt-s-3xl">
				<h2 className="display-sm text-ink mb-s-md">Feedback</h2>
				<p>
					We are constantly improving. Your feedback helps us build the best attendance calculator for students worldwide.
				</p>
			</div>
		</div>
	</div>
</Layout>
